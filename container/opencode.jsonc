{
  "$schema": "https://opencode.ai/config.json",
  // OpenCode resolves its model through LiteLLM, which runs as a separate
  // service (see docker-compose.yml). The same image works in any environment
  // because the base URL + virtual key are injected at runtime via env.
  "model": "litellm/default",
  "provider": {
    "litellm": {
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "default": {
          "name": "litellm/default",
          // DeepSeek V4 Flash supports graded reasoning effort. `high` is the
          // sweet spot for agent work — `max`/`xhigh` burn tokens for marginal
          // gains. Bumped here from the default so the agent reasons more
          // deliberately about workflow steps. The actual model slug is set in
          // container/litellm_config.yaml; this option rides along on every
          // request OpenCode sends through LiteLLM.
          "options": {
            "reasoningEffort": "high"
          }
        }
      }
    }
  },
  // Permissions — full autonomous access. This is the user's own container
  // running their own agent; there is no interactive terminal to approve
  // prompts, and any "ask" permission would hang the HTTP API indefinitely
  // (the permission prompt can't surface through /session/:id/message).
  // So every tool is set to "allow" — equivalent to a /yolo mode.
  //
  // CRITICAL: "external_directory" must be "allow" — OpenCode's worktree is
  // /app (where the process starts), but all workflow work happens under
  // /workspace. Without this, every file access outside /app triggers a
  // permission prompt that hangs the request.
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": { "*": "allow" },
    "question": "allow",
    "doom_loop": "allow"
  },
  // Official Canva MCP server (remote, OAuth). mcp-remote bridges stdio MCP
  // traffic to https://mcp.canva.com/mcp. On first launch the user completes
  // an OAuth flow; the resulting token is cached in their workspace volume so
  // subsequent launches are headless.
  //
  // The OAuth callback listener binds to 127.0.0.1:<port-from-redirectUri>.
  // We parameterize it per user via MCP_AUTH_OAUTH_PORT so the host-published
  // port (which equals this same value) routes the browser callback back
  // through: host:OAUTH_PORT -> container:RELAY_PORT -> socat ->
  // 127.0.0.1:OAUTH_PORT (opencode). Default 19876 preserves the original
  // single-user dev harness behavior when the env var is absent.
  //
  // TODO: track https://github.com/anomalyco/opencode/issues/33966 — once
  // opencode supports a configurable callback *host* (not just port), the
  // socat relay in /usr/local/bin/mcp-auth can be removed.
  "mcp": {
    "Canva": {
      "type": "remote",
      "url": "https://mcp.canva.com/mcp",
      "enabled": true,
      "oauth": {
        "redirectUri": "http://127.0.0.1:{env:MCP_AUTH_OAUTH_PORT}/mcp/oauth/callback"
      }
    },
    // xAI Grok MCP — bundled Python server, pre-synced in the image at
    // /app/mcps/grok-mcp. `uv run` reuses the baked venv. The XAI_API_KEY
    // is injected at runtime via env (see docker-compose.yml / .env).
    "grok": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/app/mcps/grok-mcp",
        "run",
        "python",
        "main.py"
      ],
      "enabled": true,
      "environment": {
        "XAI_API_KEY": "{env:XAI_API_KEY}"
      }
    },
    // Vision MCP — free-tier OpenRouter Qwen2.5-VL via the LiteLLM gateway.
    // Gives the text-only agent free image understanding for verifying renders
    // (framing, blank output, detached parts). Falls back to grok vision when
    // the free tier is rate-limited. Uses the same OPENAI_* creds as the main
    // model (LiteLLM holds the central OpenRouter key).
    "vision": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/app/mcps/vision-mcp",
        "run",
        "python",
        "main.py"
      ],
      "enabled": true,
      "environment": {
        "OPENAI_BASE_URL": "{env:OPENAI_BASE_URL}",
        "OPENAI_API_KEY": "{env:OPENAI_API_KEY}",
        "VISION_MODEL": "{env:VISION_MODEL}"
      }
    },
    // Sequential-thinking MCP — pure npx, no install step required.
    "sequentialthinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 60000
    },
    // Layerre MCP — bundled Python server, pre-synced in the image at
    // /app/mcps/layerre-mcp. Given a Canva share URL, the agent can import
    // the design as a template, edit layers, and render custom variants.
    // `uv run` reuses the baked venv. The LAYERRE_API_KEY is injected at
    // runtime via env (see docker-compose.yml / .env).
    "layerre": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/app/mcps/layerre-mcp",
        "run",
        "python",
        "main.py"
      ],
      "enabled": false,
      "environment": {
        "LAYERRE_API_KEY": "{env:LAYERRE_API_KEY}"
      }
    },
    // Blender MCP (blender-mcp) — drives a remote Blender instance running on
    // an ephemeral vast.ai GPU instance. The MCP server (this process) dials a
    // FIXED 127.0.0.1:9876 target. That loopback port is actually an SSH tunnel
    // (`ssh -NfL 9876:127.0.0.1:9876 root@gpu-ip`) that the host lease manager
    // starts inside this container when a GPU lease is acquired, and kills on
    // release. Because the dial target never changes, GPU leases come and go
    // with NO dynamic MCP config and NO OpenCode restart — only the tunnel
    // changes. When no lease is active the tunnel is absent and tool calls
    // return a connection-refused error the SKILL.md tells the agent to
    // interpret as "GPU not ready — provisioning is automatic."
    "blender": {
      "type": "local",
      // Run from the baked venv (same pattern as grok/layerre) — no `uvx` cold
      // build at runtime, so the MCP server starts instantly and OpenCode's
      // init handshake doesn't time out. The venv is pre-synced in the image at
      // /app/mcps/blender-mcp from the wp07e fork (BLENDER_MCP_REF in
      // container/Dockerfile), which carries the viewport-screenshot
      // bytes-over-socket fix that matches the addon on the GPU instance.
      "command": ["uv", "--directory", "/app/mcps/blender-mcp", "run", "blender-mcp"],
      "enabled": true,
      "environment": {
        "BLENDER_HOST": "127.0.0.1",
        "BLENDER_PORT": "9876",
        // When set, get_viewport_screenshot saves the PNG to this dir and
        // returns the file path as text (instead of an Image the text-only
        // model can't display). The agent can copy the file to the active
        // instance's exports/ for canvas display.
        "BLENDER_SCREENSHOT_DIR": "/workspace/exports"
      },
      "timeout": 120000
    }
  }
}
