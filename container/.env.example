# ─────────────────────────────────────────────────────────────────────────────
# AI OS base image — runtime environment
# Copy to .env and fill in. Never bake these into the image.
# ─────────────────────────────────────────────────────────────────────────────

# Per-user UID/GID for the non-root user inside the container.
# Set per-instance so each user's files in the mounted workspace are owned by
# them on the host. Defaults to 2000:2000.
APP_UID=2000
APP_GID=2000

# ─── OpenRouter (central, lives with LiteLLM only) ──────────────────────────
# YOUR real OpenRouter API key. Consumed by litellm_config.yaml. The container
# image NEVER sees this — only the LiteLLM service does.
OPENROUTER_API_KEY=sk-or-v1-replace-with-your-real-openrouter-key

# ─── LiteLLM proxy admin ────────────────────────────────────────────────────
# Master key for the LiteLLM service itself (used to mint per-user virtual
# keys, read spend, etc.). Pick any strong random string.
LITELLM_MASTER_KEY=sk-litellm-master-replace-me

# ─── Per-container credentials (what each AI OS container actually gets) ────
# These are NOT your OpenRouter key. They are a virtual key LiteLLM issues per
# tenant (see README.md → "Onboarding a new user"). LiteLLM maps this back to
# the central OPENROUTER_API_KEY and applies per-user budgets/routing.
#
# In dev / single-user mode you can point the container straight at the master
# key. In multi-user production, generate one virtual key per tenant.
OPENAI_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=sk-litellm-virtual-key-replace-me

# ─── Canva MCP (per-user OAuth) ────────────────────────────────────────────
# No static token is required — the official Canva MCP server completes an
# OAuth flow on first launch (open the URL `npx mcp-remote` prints, approve in
# the browser). The resulting token is cached in the user's workspace volume
# and reused on subsequent launches.
