# ─── Seed user (auto-created on first DB init) ──────────────────────────────
SEED_USERNAME=your_username
SEED_PASSWORD=your_password

# ─── GPU orchestration (Blender workflow) ───────────────────────────────────
# These are read by the HOST Next.js process (web/src/lib/gpu/), NOT the
# per-user containers. The host provisions/destroys vast.ai GPU instances on
# behalf of Blender workflow lanes; containers only get an SSH tunnel to the
# Blender socket. NEVER put these in container/.env — they're platform billing
# credentials.
#
# Required for the Blender workflow to rent GPU instances:
VAST_API_KEY=your_vast_ai_api_key

# Optional — enables Sketchfab model downloads in the Blender workflow.
# The AI agent can search/import Sketchfab models via the blender-mcp addon.
# Get a token at: Sketchfab → Settings → Password & API tab → copy API token.
# Passed to the GPU instance as BLENDERMCP_SKETCHFAB_API_KEY at acquire time
# (env-var only — never written into scene.blend). Leave unset to disable.
# SKETCHFAB_API_KEY=your_sketchfab_api_token

# Optional tuning (defaults shown):
# GPU_MAX_DPH=0.09            # max $/hr to pay for a GPU instance.
#                             # NOTE: with GPU_GEOLOCATIONS set to a tight region
#                             # (e.g. TW,JP,KR,SG) and the default allowlist
#                             # (RTX 4060/4060Ti/5060/5060Ti/A4000), $0.09 is a
#                             # narrow intersection — if the regional market for
#                             # those models rises above the cap, leases sit in
#                             # 'queued' until an offer appears or the queue
#                             # timeout (below) fires. Raise this to broaden
#                             # availability at higher cost.
# GPU_MAX_CONCURRENT=2        # max simultaneous GPU instances platform-wide
# GPU_IDLE_TIMEOUT_MS=600000  # auto-release idle leases after this many ms
# GPU_QUEUE_TIMEOUT_MS=600000 # give up on a queued lease after this many ms
#                             # (default 10 min). After the timeout the lease
#                             # moves to 'destroyed' with a clear message and the
#                             # "Acquire GPU" button reappears, instead of
#                             # retrying invisibly forever (the original "stuck
#                             # on Waiting for GPU" bug). 0 = never time out.
# GPU_IMAGE=nvidia/cuda:12.4.1-runtime-ubuntu22.04
# GPU_IMAGE=walkerp07/blender-mcp:latest  # pre-built image (Blender+addon+Xvfb baked in, ~5s boot vs 5-7min)
# GPU_DISK_GB=50              # instance disk (storage billed until destroy)
# BLENDER_VERSION=4.5.11      # Blender version downloaded on GPU instances (or "latest-4.5")
#
# GPU geolocation filter — restrict offers to these 2-letter country codes.
# Set this to countries NEAR THE HOST running this app (where the SSH tunnel
# originates). Long-distance tunnels are frequently dropped, causing the
# blender-mcp socket to appear dead. Leave unset/empty for worldwide.
#
#   Asia (dev machine):   GPU_GEOLOCATIONS=TW,JP,KR,SG
#   US production server: GPU_GEOLOCATIONS=US,CA
#   Europe:               GPU_GEOLOCATIONS=DE,NL,FR,SE,FI
#
#GPU_GEOLOCATIONS=TW,JP,KR,SG

